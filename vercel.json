{
    "builds": [
        {
            "src": "client/next.config.js",
            "use": "@vercel/next"
        },
        {
            "src": "server/src/server.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "server/src/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/server/src/server.ts"
        },
        {
            "src": "/(.*)",
            "dest": "/client/$1"
        }
    ]
}